# Report as xterm-256color so remote servers don't choke on missing ghostty terminfo
term = xterm-256color

# Font — matches current iTerm setup
font-family = Hack Nerd Font
font-size = 13

# Theme — Catppuccin Mocha (matches tmux status bar)
theme = Catppuccin Mocha

# Quick terminal (Quake mode) — tilde drops it over every app instantly
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0
keybind = global:grave_accent=toggle_quick_terminal
keybind = ctrl+shift+alt+grave_accent=text:\x60

# tmux-style splits (Ctrl+b leader, same as .tmux.conf)
keybind = ctrl+b>shift+backslash=new_split:right
keybind = ctrl+b>shift+5=new_split:right
keybind = ctrl+b>minus=new_split:down
keybind = ctrl+b>shift+quote=new_split:down

# tmux-style pane navigation (vim keys)
keybind = ctrl+b>h=goto_split:left
keybind = ctrl+b>j=goto_split:bottom
keybind = ctrl+b>k=goto_split:top
keybind = ctrl+b>l=goto_split:right

# tmux-style tabs
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>n=next_tab
keybind = ctrl+b>p=previous_tab

# Window (matches wezterm window_padding left=8 right=8 top=6 bottom=6)
initial-window = false
window-decoration = false
background-opacity = 0.92
background-blur-radius = 20
mouse-hide-while-typing = true
copy-on-select = clipboard
window-padding-x = 8
window-padding-y = 6
