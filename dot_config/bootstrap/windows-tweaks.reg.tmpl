Windows Registry Editor Version 5.00

; ============================================================================
; windows-tweaks.reg — reproduces the registry state the setup depends on.
; Double-click on a fresh machine, then restart Explorer. See WINDOWS-REGISTRY.md.
; ============================================================================

; --- Free Win+L from the lock action (so Raycast can bridge it) ---
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Policies\System]
"DisableLockWorkstation"=dword:00000001

; --- Taskbar on all monitors ---
[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced]
"MMTaskbarEnabled"=dword:00000001

; NOTE: taskbar AUTO-HIDE is a binary blob in StuckRects3 and can't be set
; cleanly here — toggle it in Settings (see WINDOWS-REGISTRY.md step 1).
;
; NOTE: EnableAutoTray intentionally NOT set (we don't use the Windows tray).

; Classic (Win10) right-click context menu on Win11 — replaces the Windhawk mod
; (Windhawk was uninstalled; it crashed File Pilot via DLL injection)
[HKEY_CURRENT_USER\Software\Classes\CLSID\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\InprocServer32]
@=""

; Notifications: keep the Windows backend ON (so YASB's notification widget can
; read them) but turn OFF toast popups, so YASB's bell is the ONLY surface.
; (Do NOT set DisableNotificationCenter — it kills the backend YASB reads.)
[HKEY_CURRENT_USER\SOFTWARE\Microsoft\Windows\CurrentVersion\PushNotifications]
"ToastEnabled"=dword:00000000

; Ctrl+Shift+Esc / all Task Manager invocations -> System Informer (IFEO debugger)
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options\taskmgr.exe]
"Debugger"="{{ .chezmoi.homeDir | replace "/" "\\\\" }}\\scoop\\apps\\systeminformer\\current\\SystemInformer.exe"

; (IrfanView image-default experiment removed — it broke File Explorer/File Pilot
;  thumbnails. Images use the Windows default viewer, which keeps native previews.)

; ShareX autostart (its PrtSc hotkeys only work while ShareX is running)
[HKEY_CURRENT_USER\SOFTWARE\Microsoft\Windows\CurrentVersion\Run]
"ShareX"="\"{{ .chezmoi.homeDir | replace "/" "\\\\" }}\\scoop\\apps\\sharex\\current\\ShareX.exe\" -silent"

; --- XDG_CONFIG_HOME system-wide: makes Windows behave Unix-like for config PATHS, so XDG-aware
;     apps (nvim, bat, ...) read ~/.config — exactly where the dotfiles deploy. Templated so it
;     survives the yabo reset. Needs a relog to take effect. (nvim also wants ~/.config/nvim to
;     exist — on this machine it's a junction to %LOCALAPPDATA%\nvim; the LazyVim external should
;     populate it on a fresh box once it's un-broken.)
[HKEY_CURRENT_USER\Environment]
"XDG_CONFIG_HOME"="{{ .chezmoi.homeDir | replace "/" "\\\\" }}\\.config"

; --- Disable Copilot (inerts Win+C, removes its taskbar button). Win+G/Game Bar left ON. ---
[HKEY_CURRENT_USER\Software\Policies\Microsoft\Windows\WindowsCopilot]
"TurnOffWindowsCopilot"=dword:00000001

[HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced]
"ShowCopilotButton"=dword:00000000
; Disabled Win+<key> combos — all redundant (Raycast / Open-Shell / YASB cover them):
;   I=Settings  X=power-menu  N=notifications(YASB)  Q,S=search(Raycast)  B=taskbar-focus
;   O=orientation  R=Run (Raycast runs commands/apps)
; (Win+K=cast and Win+H=dictation are already dead — GlazeWM eats lwin+k / lwin+h.)
; Kept: Win+A quick-settings, Win+E/P/V/G/D + glaze's h/j/k/t/m/d/1-9. (lwin+shift+r=glaze reload, unaffected.)
; DisabledHotkeys = the letters; needs an Explorer restart / relogin to take effect.
"DisabledHotkeys"="IXNQSBOR"

; --- Widgets (Win+W) is removed at the app level, not here: Get-AppxPackage *WebExperience* | Remove-AppxPackage ---
