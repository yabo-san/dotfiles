{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/logo.txt",
    "padding": { "top": 1, "right": 2 }
  },
  "modules": [
    {{ if eq .chezmoi.os "windows" -}}
    { "type": "title", "format": "yabo@home" },
    {{- else -}}
    "title",
    {{- end }}
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "break",
    "colors"
  ]
}
