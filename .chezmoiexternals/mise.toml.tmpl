{{/* Only fetch mise on non-Windows (mac/Linux). On Windows, scoop manages tools. */}}
{{ if ne .chezmoi.os "windows" }}
[".local/bin/mise"]
type = "file"
executable = true
{{ if eq .chezmoi.os "darwin" }}
url = "https://github.com/jdx/mise/releases/download/v2026.6.11/mise-v2026.6.11-macos-{{.chezmoi.arch}}"
{{ else }}
url = "https://github.com/jdx/mise/releases/download/v2026.6.11/mise-v2026.6.11-{{.chezmoi.os}}-{{.chezmoi.arch}}"
{{ end }}
{{ end }}
