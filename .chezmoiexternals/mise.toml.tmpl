{{/* Only fetch mise on non-Windows (mac/Linux). On Windows, scoop manages tools.
     Was: gated on a single hardcoded mac hostname, which fired wrong on Windows. */}}
{{ if ne .chezmoi.os "windows" }}
[".local/bin/mise"]
type = "file"
executable = true
url = "https://mise.jdx.dev/mise-latest-{{.chezmoi.os}}-{{.chezmoi.arch}}"
{{ end }}
