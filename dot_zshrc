# ~~~~~~~~~~~~~~~ History ~~~~~~~~~~~~~~~~~~~~~~~~


HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

setopt HIST_IGNORE_SPACE # dont save when prefixed with SPACE
setopt HIST_IGNORE_DUPS # dont save duplicate lines
setopt SHARE_HISTORY # share history between sessions

# Fastfetch on startup — skip in quake terminal and nested shells (matches PS profile)
if command -v fastfetch > /dev/null && [[ -z "$QUAKE_TERM" ]] && [[ "$SHLVL" -eq 1 ]]; then
  fastfetch
fi

# ~~~~~~~~~~~~~~~ Prompt ~~~~~~~~~~~~~~~~~~~~~~~~


PURE_GIT_PULL=0

if [[ "$OSTYPE" == darwin* ]]; then
  fpath+=("$(brew --prefix)/share/zsh/site-functions")
else
  fpath+=($HOME/.zsh/pure)
fi
autoload -U promptinit; promptinit

prompt pure


# enable zsh vi-mode
bindkey -v
export KEYTIMEOUT=1 # make switching between modes faster


# ~~~~~~~~~~~~~~~ Environment Variables ~~~~~~~~~~~~~~~~~~~~~~~~


if command -v nvim > /dev/null ; then
  export EDITOR="nvim"
  export VISUAL="nvim"
fi

export LANG="en_US.UTF-8"

# XDG — makes tools read from ~/.config consistently across all 3 OSes
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# bat config path (stops bat hanging on long files, keeps our style)
export BAT_CONFIG_PATH="$HOME/.config/bat/config"


# ~~~~~~~~~~~~~~~ Mise ~~~~~~~~~~~~~~~~~~~~~~~~

# needed to add homebrew mise to the path
export PATH="/opt/homebrew/bin:$PATH"


if command -v mise > /dev/null ; then
  eval "$($HOME/.local/bin/mise activate zsh)"
fi


# ~~~~~~~~~~~~~~~ Completion ~~~~~~~~~~~~~~~~~~~~~~~~


autoload -Uz compinit && compinit

if command -v fzf > /dev/null ; then
  source <(fzf --zsh)

  # fd as the default find engine
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

  # Catppuccin Mocha palette + bat previews
  export FZF_DEFAULT_OPTS='
    --height 40% --layout=reverse --border
    --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8
    --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc
    --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8'
  export FZF_CTRL_T_OPTS='--preview "bat --color=always --style=numbers --line-range=:300 {}" --preview-window=right:60%:wrap'
  export FZF_ALT_C_OPTS='--preview "ls -la {}" --preview-window=right:50%'
fi

# zoxide — smart cd (--cmd cd makes `cd <partial>` jump by frecency)
if command -v zoxide > /dev/null ; then
  eval "$(zoxide init zsh --cmd cd)"
fi

# atuin — magic shell history (Ctrl+R, synced). Loads after fzf so it owns Ctrl+R.
if command -v atuin > /dev/null ; then
  eval "$(atuin init zsh)"
fi

if command -v flux > /dev/null ; then
  source <(flux completion zsh)
fi


if command -v mise > /dev/null ; then
  source <(mise completion zsh)
fi


# Up/down = prefix history search (matches PSReadLine HistorySearchBackward)
autoload -U up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search
bindkey "^[[B" down-line-or-beginning-search

# zsh-autosuggestions (gray ghost text, matches PSReadLine PredictionSource)
[[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# zsh-syntax-highlighting (red = bad command, green = good, matches PSReadLine)
[[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ~~~~~~~~~~~~~~~ Aliases ~~~~~~~~~~~~~~~~~~~~~~~~


alias v=nvim
alias gp="git pull"
alias gs="git status"
alias lg=lazygit

if command -v bat > /dev/null ; then
  alias cat="bat"
fi

if command -v lsd > /dev/null ; then
  alias ls="lsd"
  alias ll="ls -lgh"
  alias la='ls -lathr'
  alias lla='ls -lgha'
  alias lt='ls --tree'
fi

# modern CLI pack (parity with Windows) — alias to classic names where present
command -v fastfetch > /dev/null && alias ff='fastfetch' && alias neofetch='fastfetch'
command -v btop  > /dev/null && alias top='btop'
command -v dust  > /dev/null && alias du='dust'
command -v duf   > /dev/null && alias df='duf'
command -v procs > /dev/null && alias ps='procs'

# yazi — terminal file manager (y); cd's the shell to where you quit
if command -v yazi > /dev/null ; then
  function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
      builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
  }
fi
alias k='kubectl'
alias kgp='kubectl get pods'
source <(kubectl completion zsh)
compdef __start_kubectl k
alias icloud='cd ~/Library/Mobile\ Documents/com~apple~CloudDocs'
alias lastmod='find . -type f -not -path "*/\.*" -exec ls -lrt {} +'
alias sb='cd ~/Library/Mobile\ Documents/iCloud~md~obsidian/Documents/sb'

# grep → rg, find → fd, wget → curl (mirrors unix-aliases.ps1)
command -v rg   > /dev/null && alias grep='rg'
command -v fd   > /dev/null && alias find='fd'
alias wget='curl -L -O'

# mkcd — mkdir + cd (PS: function mkcd)
mkcd() { mkdir -p "$1" && cd "$1" }

# reload — re-source zshrc (PS: function reload)
alias reload='source ~/.zshrc'

unalias dormin 2>/dev/null
dormin() {
  if [[ $# -eq 0 ]]; then
    claude --dangerously-skip-permissions --resume
  else
    claude --dangerously-skip-permissions "$@"
  fi
}
